<!--pages/home.wxml-->
<!-- 用户主页 -->
<view class="container">
  <!-- 1. 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">
      <text class="avatar-icon">👤</text>
    </view>

    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '微信用户'}}</text>
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-num">{{userInfo.totalRunCount || 0}}</text>
          <text class="stat-label">总次数</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{userInfo.totalDistance || 0}}</text>
          <text class="stat-label">总公里数</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 2. 跑步历史记录区 -->
  <view class="history-card">
    <text class="card-title">跑步历史</text>
    <scroll-view class="history-list" scroll-y>
      <view wx:for="{{historyList}}" wx:key="_id" class="history-item">
        <view class="history-info">
          <text class="history-date">{{item.createTime}}</text>
          <text class="history-detail">{{item.duration}}分钟 · {{item.distance}}公里</text>
        </view>
        <text class="history-calories">{{item.calories}}千卡</text>
      </view>
      <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMoreHistory">加载更多</view>
      <view wx:elif="{{historyList.length > 0}}" class="no-more">已经到底啦</view>
      <view wx:else class="empty-tip">还没有跑步记录，快去记录第一条吧~</view>
    </scroll-view>
  </view>
</view>