<view class="container" style="padding: 100rpx; text-align: center;">
  <button open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" style="width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto; border: none; background: #f5f5f5;">
    <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" style="width:100%; height:100%; border-radius:50%"></image>
    <view wx:else style="font-size: 28rpx; color: #666;">点击头像</view>
  </button>
  <input placeholder="请输入昵称" bindinput="onNicknameInput" value="{{nickName}}" style="margin-top: 60rpx; padding: 20rpx; border: 1rpx solid #eee; border-radius: 12rpx; width: 80%;"></input>
  <button bindtap="handleRegister" style="margin-top: 60rpx; background: #07c160; border: none; border-radius: 12rpx; padding: 20rpx 40rpx; font-size: 32rpx;">完成注册</button>
</view>