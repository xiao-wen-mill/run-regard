<view class="container">
  <!-- 固定纯色圆形头像，无授权功能 -->
  <view class="avatar-placeholder">
    <text class="icon">👤</text>
  </view>

  <!-- 昵称输入框 -->
  <input class="nick-input" placeholder="请输入昵称" bindinput="onNickInput" value="{{nickName}}"/>

  <!-- 微信注册按钮 -->
  <button 
    bindtap="handleRegister" 
    class="register-btn"
    disabled="{{!isChecked || !nickName}}"
  >
    微信注册
  </button>

  <!-- 勾选框（已经放在这里，样式会自动定位到80%位置） -->
  <view class="checkbox-wrap">
    <checkbox checked="{{isChecked}}" bindtap="toggleCheck" color="#07c160"></checkbox>
    <text class="checkbox-text">我已阅读并同意授权信息</text>
  </view>
</view>