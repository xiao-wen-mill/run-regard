<view class="container" style="padding: 100rpx; text-align: center;">
  <view style="margin-bottom: 80rpx;">
    <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" style="width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto;"></image>
    <view wx:else style="width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
      <text style="font-size: 28rpx; color: #666;">点击授权</text>
    </view>
  </view>
  <view wx:if="{{nickName}}" style="margin-bottom: 60rpx; font-size: 32rpx;">{{nickName}}</view>
  <button bindtap="getProfile" style="background: #07c160; border: none; border-radius: 12rpx; padding: 20rpx 40rpx; font-size: 32rpx;">微信授权注册</button>
</view>