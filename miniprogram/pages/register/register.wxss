/* pages/register/register.wxss *//* 页面整体 */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 120rpx 50rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;

  /* 新增：用于定位勾选框 */
  position: relative;
}

/* 固定纯色圆形头像 */
.avatar-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #e8f5f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.05);
}
.icon {
  font-size: 80rpx;
  color: #07c160;
}

/* 昵称输入框 */
.nick-input {
  width: 100%;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 80rpx;
  border: 1rpx solid #eee;
  box-sizing: border-box;
}

/* 注册按钮 */
.register-btn {
  width: 100%;
  background: #07c160;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(7,193,96,0.2);
  margin-bottom: 100rpx;
}
.register-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* 勾选区域 —— 已修改：固定在页面 80% 高度 */
.checkbox-wrap {
  display: flex;
  align-items: center;

  /* 核心定位：页面 80% 高度 */
  position: absolute;
  top: 80%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.checkbox-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 10rpx;
}